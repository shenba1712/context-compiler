{
  "name": "context-compiler",
  "version": "0.1.0",
  "description": "Task-aware, token-budgeted file-to-markdown compiler for AI agents (MCP server + web demo)",
  "type": "module",
  "bin": {
    "context-compiler": "dist/server.js"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json",
    "test": "npm run build && node dist/tests/test.js",
    "mcp": "node dist/server.js",
    "web": "node dist/web.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "express": "^4.21.0",
    "js-tiktoken": "^1.0.15",
    "multer": "^2.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
